{
  "name": "research-notes-site",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "tsx scripts/clean-dist.ts && npm run validate-env && tsx scripts/generate-headers.ts",
    "build": "astro build && pagefind --site dist",
    "postbuild": "tsx scripts/check-build.ts",
    "preview": "astro preview",
    "check": "astro check && npm run validate-env && npm run validate-content",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "sync-content": "tsx scripts/sync-content.ts && tsx scripts/sync-diffusion.ts",
    "sync-content:write": "tsx scripts/sync-content.ts --write && tsx scripts/sync-diffusion.ts --write",
    "validate-content": "tsx scripts/validate-content.ts",
    "validate-env": "tsx scripts/validate-env.ts",
    "generate-headers": "tsx scripts/generate-headers.ts",
    "check:build": "tsx scripts/check-build.ts",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.24.0",
    "astro": "^7.0.9",
    "gray-matter": "^4.0.3",
    "lucide": "^1.24.0",
    "mermaid": "^11.16.0",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "cheerio": "^1.2.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}

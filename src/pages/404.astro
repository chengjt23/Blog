---
import { ArrowLeft, Search } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBasePath } from '../lib/paths';
---

<BaseLayout title="页面不存在" description="请求的页面不存在。" pageIndexable={false}>
  <div class="page-shell">
    <header>
      <p class="eyebrow">404</p>
      <h1 class="page-title">页面不存在</h1>
      <p class="page-lead">链接可能已经改变，或内容尚未进入公开发布范围。</p>
    </header>
    <section class="section-band footer-links">
      <a class="text-link" href={withBasePath('/')}>
        <ArrowLeft size={17} aria-hidden="true" /> 返回首页
      </a>
      <a class="text-link" href={withBasePath('/search/')}>
        <Search size={17} aria-hidden="true" /> 搜索内容
      </a>
    </section>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBasePath } from '../../lib/paths';
---

<BaseLayout title="Blog" description="生成建模、随机过程与最优传输的系统技术 Blog。">
  <div class="page-shell">
    <header>
      <p class="eyebrow">Blog</p>
      <h1 class="page-title">Blog</h1>
    </header>

    <article class="section-band series-feature">
      <div>
        <p class="eyebrow">5 chapters · v1.0</p>
        <h2>
          <a class="blog-title-link" href={withBasePath('/blog/diffusion/')}>Diffusion</a>
        </h2>
        <p>介绍 Diffusion 的基本结构、DDPM 训练、score dynamics、现代生成系统与 Flow 边界。</p>
      </div>
      <a
        class="blog-figure-link"
        href={withBasePath('/blog/diffusion/')}
        aria-label="进入 Diffusion Blog"
      >
        <figure>
          <img
            src={withBasePath('/images/diffusion/d1_forward_marginals.png')}
            width="1854"
            height="1276"
            alt="数据分布随前向扩散逐步接近 Gaussian"
          />
          <figcaption>加噪如何把复杂数据逐步变成可控的生成路径。</figcaption>
        </figure>
      </a>
    </article>

    <article class="section-band series-feature">
      <div>
        <p class="eyebrow">5 chapters · v1.0</p>
        <h2>
          <a class="blog-title-link" href={withBasePath('/blog/schrodinger-bridge/')}>
            Schrödinger Bridge
          </a>
        </h2>
        <p>从问题定义、精确结构与计算出发，进入神经近似，并以方法选择和应用边界收束。</p>
      </div>
      <a
        class="blog-figure-link"
        href={withBasePath('/blog/schrodinger-bridge/')}
        aria-label="进入 Schrödinger Bridge Blog"
      >
        <figure>
          <img
            src={withBasePath('/images/bridge/B5_entropic_couplings.png')}
            width="1887"
            height="647"
            alt="不同熵温度下的最优端点耦合"
          />
          <figcaption>不同 entropy temperature 下的端点耦合。</figcaption>
        </figure>
      </a>
    </article>
  </div>
</BaseLayout>

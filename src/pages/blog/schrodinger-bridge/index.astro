---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { chapterUrl, getChapters } from '../../../lib/content';

const chapters = await getChapters();
---

<BaseLayout
  title="Schrödinger Bridge"
  description="5 章自顶向下的系统 Blog：从 Schrödinger Bridge 的问题定义与精确结构，进入计算、神经近似和方法选择。"
>
  <div class="page-shell">
    <header>
      <p class="eyebrow">Blog · B1-B5</p>
      <h1 class="page-title">Schrödinger Bridge</h1>
      <p class="page-lead">
        从顶层问题逐层进入精确数学结构、计算方法和高维近似，最后回答什么时候真正需要 Bridge。
      </p>
    </header>

    <section class="section-band" aria-labelledby="reading-route">
      <h2 class="section-heading" id="reading-route">阅读路线</h2>
      <p class="page-lead">
        建议按 B1 到 B5
        顺序阅读：先建立全景图，再理解精确解的结构与计算；随后进入神经近似，最后根据任务信息判断是否值得使用
        Bridge。
      </p>
    </section>

    <section class="section-band" aria-labelledby="all-chapters">
      <h2 class="section-heading" id="all-chapters">全部文章</h2>
      <ol class="chapter-list">
        {
          chapters.map((chapter) => (
            <li>
              <a class="chapter-row" href={chapterUrl(chapter)}>
                <span class="chapter-number">B{chapter.data.order}</span>
                <span class="chapter-row-title">{chapter.data.title}</span>
                <span class="chapter-row-arrow" aria-hidden="true">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </section>
  </div>
</BaseLayout>

---
import type { ChapterEntry } from '../lib/content';
import { chapterUrl } from '../lib/content';

interface Props {
  chapters: ChapterEntry[];
  currentSlug: string;
  prefix?: 'B' | 'D';
}

const { chapters, currentSlug, prefix = 'B' } = Astro.props;
---

<ul class="series-nav-list">
  {
    chapters.map((chapter) => (
      <li>
        <a
          href={chapterUrl(chapter)}
          aria-current={chapter.data.slug === currentSlug ? 'page' : undefined}
        >
          {prefix}
          {chapter.data.order} · {chapter.data.title}
        </a>
      </li>
    ))
  }
</ul>
